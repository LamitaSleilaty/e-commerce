
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ecommerce_ai?schema=public"


PORT=4000
NODE_ENV=development
CLIENT_URL="http://localhost:3000"

JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="7d"

OPENCLAW_API_KEY="your-openclaw-gateway-token"
OPENCLAW_API_URL="http://127.0.0.1:18789/v1"
OPENCLAW_MODEL="openclaw/shopassist"


N8N_WEBHOOK_BASE_URL="http://localhost:5678/webhook"
N8N_API_KEY="your-n8n-webhook-secret"

GOOGLE_CLIENT_ID="your-oauth-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-oauth-client-secret"
GOOGLE_REFRESH_TOKEN="obtained-by-running-the-script-above"
GMAIL_SENDER_EMAIL="you@gmail.com"
