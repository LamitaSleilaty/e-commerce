# PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ecommerce_ai?schema=public"

# Server
PORT=4000
NODE_ENV=development
CLIENT_URL="http://localhost:3000"

# Auth
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="7d"

# OpenClaw AI assistant
# Requires a local OpenClaw gateway (npm i -g openclaw && openclaw onboard),
# with gateway.http.endpoints.chatCompletions.enabled=true and a dedicated
# agent (see backend/README.md "How OpenClaw fits in").
OPENCLAW_API_KEY="your-openclaw-gateway-token"
OPENCLAW_API_URL="http://127.0.0.1:18789/v1"
OPENCLAW_MODEL="openclaw/shopassist"

# n8n automation
N8N_WEBHOOK_BASE_URL="http://localhost:5678/webhook"
N8N_API_KEY="your-n8n-webhook-secret"

# Gmail API (sends the account-verification email directly, bypassing n8n)
# Client ID/Secret come from a Google Cloud OAuth client with the Gmail API enabled.
# Run `node scripts/get-gmail-refresh-token.js` once to obtain GOOGLE_REFRESH_TOKEN.
GOOGLE_CLIENT_ID="your-oauth-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-oauth-client-secret"
GOOGLE_REFRESH_TOKEN="obtained-by-running-the-script-above"
GMAIL_SENDER_EMAIL="you@gmail.com"
